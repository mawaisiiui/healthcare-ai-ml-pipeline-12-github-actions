# ------------------------------
# Python cache / compiled files
# ------------------------------
__pycache__/
*.py[cod]
*$py.class

# ------------------------------
# Virtual environments
# ------------------------------
.venv/
venv/
env/
ENV/

# ------------------------------
# Jupyter / notebooks
# ------------------------------
.ipynb_checkpoints/
*.ipynb

# ------------------------------
# Git
# ------------------------------
.git/
.gitignore

# ------------------------------
# Local configs / secrets
# ------------------------------
.env
.env.*
*.env

# ------------------------------
# Logs
# ------------------------------
logs/
*.log

# ------------------------------
# MLflow / experiment tracking
# ------------------------------
mlruns/
mlflow.db

# ------------------------------
# DVC (optional - depends on setup)
# ------------------------------
.dvc/
.dvcignore

# ------------------------------
# OS files
# ------------------------------
.DS_Store
Thumbs.db

# ------------------------------
# Build / dist
# ------------------------------
build/
dist/
*.egg-info/

# ------------------------------
# IDE / Editor files
# ------------------------------
.vscode/
.idea/

# ------------------------------
# Tests (optional for production)
# ------------------------------
tests/
pytest_cache/
.coverage

# ------------------------------
# Large unnecessary files
# ------------------------------
*.csv
*.parquet
*.zip
*.tar.gz

